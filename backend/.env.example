# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
    =sk-ant-...

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────────
# All three values come from Meta Developer Console → Your App → WhatsApp → API Setup

# 1. Permanent access token (or a temporary token for testing)
WHATSAPP_ACCESS_

# 2. Phone Number ID (not the phone number itself — the ID shown in the API Setup page)
WHATSAPP_PHONE_NUMBER_ID=1424825939271627

# 3. Any string you choose — must match exactly what you enter in Meta webhook settings
WHATSAPP_VERIFY_TOKEN=barbershop_verify


# ── How to set up Meta WhatsApp Cloud API ─────────────────────────────────────
#
# Step 1 — Create a Meta app
#   → https://developers.facebook.com/apps
#   → Create App → Business → Add "WhatsApp" product
#
# Step 2 — Get credentials
#   → WhatsApp → API Setup
#   → Copy "Phone Number ID" → WHATSAPP_PHONE_NUMBER_ID
#   → Generate or copy access token → WHATSAPP_ACCESS_TOKEN
#
# Step 3 — Expose your local backend
#   → Install ngrok: https://ngrok.com
#   → Run: ngrok http 5000
#   → Copy the https URL, e.g. https://abc123.ngrok-free.app
#
# Step 4 — Register the webhook
#   → WhatsApp → Configuration → Webhooks
#   → Callback URL: https://abc123.ngrok-free.app/webhook/whatsapp
#   → Verify token: whatever you set as WHATSAPP_VERIFY_TOKEN
#   → Subscribe to: messages
#
# Step 5 — Add a test phone number
#   → WhatsApp → API Setup → To: add your personal WhatsApp number
#
# Step 6 — Start the server and send a message to your test number
#   → bash start.sh
